# SFTP Connection Settings
SFTP_HOST=sftp.gatewayedi.com
SFTP_PORT=22
SFTP_USERNAME=your_site_id
SFTP_PASSWORD=your_password

# Remote directory containing .rmt files
SFTP_REMOTE_DIR=remit/

# Local directories
RAW_DATA_DIR=./data/raw/
PROCESSED_DATA_DIR=./data/processed/
OUTPUT_DIR=./output/

# File handling: "skip" or "overwrite"
FILE_EXISTS_BEHAVIOR=skip
